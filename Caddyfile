:{$PORT:3000} {
	root * /app/dist
	encode gzip

	# Cache hashed assets (JS/CSS bundles with content hashes in filenames)
	@hashedAssets {
		path /assets/*
	}
	header @hashedAssets Cache-Control "public, max-age=31536000, immutable"

	# Short cache for everything else (HTML, icons, etc.)
	@staticFiles {
		not path /assets/*
		file
	}
	header @staticFiles Cache-Control "public, max-age=3600"

	# SPA fallback: serve index.html for any path that doesn't match a real file
	try_files {path} /index.html

	file_server
}
